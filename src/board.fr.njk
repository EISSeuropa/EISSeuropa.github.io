<header class="page-header">
  <div class="container">
    <span class="eyebrow">À propos</span>
    <h1>L'équipe</h1>
    <p class="page-lead">
      Les membres de notre bureau conseillent et orientent l'organisation, notamment à travers
      des groupes de travail thématiques (WG). Une petite équipe de soutien assure les opérations
      quotidiennes.
    </p>
    <p class="page-lead muted" style="font-size: var(--fs-sm); margin-top: var(--space-3);">
      <em>Les noms, affiliations et thèmes de recherche ci-dessous restent dans la langue d'origine.</em>
    </p>
  </div>
</header>

{%- if boardSorted.leadership and boardSorted.leadership.length %}
<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Direction</h2>
    <div class="people-grid">
      {%- for person in boardSorted.leadership %}
        {%- include "person-card.njk" %}
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Membres du bureau</h2>
    <div class="people-grid">
      {%- for person in boardSorted.boardMembers %}
        {%- include "person-card.njk" %}
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Personnel de soutien</h2>
    <div class="people-grid">
      {%- for person in boardSorted.support %}
        {%- include "person-card.njk" %}
      {%- endfor %}
    </div>

    {%- if boardSorted.formUrl %}
    <p class="board-update-link">
      <a href="{{ boardSorted.formUrl }}" target="_blank" rel="noopener">
        Membre de l'équipe EISS&nbsp;? Mettez à jour votre bio →
      </a>
    </p>
    {%- endif %}
  </div>
</section>
