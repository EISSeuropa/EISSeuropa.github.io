        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-secondary btn-sm" href="https://netsec-cost.eu/" target="_blank" rel="noopener">
            Visit netsec-cost.eu {{ icon("external-link") }}
          </a>
