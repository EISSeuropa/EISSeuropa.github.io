{% from "icons.njk" import icon %}

<section class="hero" aria-labelledby="hero-title-2026">
  <div class="hero-bg" aria-hidden="true">
    <img src="/assets/images/8e43301e-7945-4a0c-aac2-04719ac702a8-1600x900.jpg"
         alt=""
         loading="eager"
         fetchpriority="high"
         width="1600" height="900">
  </div>
  <div class="container hero-inner">
    <p class="reveal" style="font-size: var(--fs-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: hsl(0 0% 100% / 0.85); margin-bottom: var(--space-3);">
      Next Annual Conference
    </p>
    <h1 id="hero-title-2026" class="reveal reveal-delay-1" style="font-size: clamp(2.25rem, 1.6rem + 3vw, 4rem);">
      European Security Studies Conference 2026
    </h1>
    <p class="hero-tagline reveal reveal-delay-2">
      Jointly organised by the COST Action NetSec, the European Initiative for Security Studies (EISS),
      and Stockholm University.
    </p>
    {%- set _live2026 = conferences.byYear["2026"] -%}
    {%- set _liveShown = _live2026 and _live2026.livestreamUrl and _live2026.endDate >= conferences.today -%}
    <div class="hero-actions reveal reveal-delay-3">
      {%- if _liveShown %}
      <a class="btn btn-primary hero-watch-live" href="{{ _live2026.livestreamUrl }}" target="_blank" rel="noopener">
        <span class="hero-watch-live__dot" aria-hidden="true"></span>{{ icon("video") }} Watch the livestream
      </a>
      {%- endif %}
      <a class="btn {{ 'btn-ghost' if _liveShown else 'btn-primary' }}" href="#programme">{{ icon("file-text") }} View programme</a>
      <a class="btn btn-ghost" href="#venue">{{ icon("map-pin") }} Host &amp; venue</a>
    </div>
    <p class="reveal reveal-delay-3" style="margin-top: var(--space-6); font-size: var(--fs-sm); color: hsl(0 0% 100% / 0.9);">
      <strong>11 - 12 June 2026</strong>
      <span aria-hidden="true">&nbsp;·&nbsp;</span>
      Stockholm University, Sweden
    </p>
    {# Live registration-status badge. Computed from today vs. the
       conference dates in src/_data/conferences.js; CTA URL comes
       from the Indico sync in src/_data/indico.json. #}
    {% set year = "2026" %}
    <div class="reveal reveal-delay-3 conf-status-row">
      {% include "registration-badge.njk" %}
      {% include "countdown.njk" %}
    </div>
    {%- set _reg2026 = conferences.byYear["2026"] -%}
    {%- if _reg2026 and _reg2026.registrationStatus == "closed" -%}
    <p class="reveal reveal-delay-3" style="margin-top: var(--space-4); font-size: var(--fs-sm); color: hsl(0 0% 100% / 0.9); max-width: 42rem;">
      Registration has closed. You can still follow along: the <a href="#programme" style="color:#fff;text-decoration:underline;">programme</a> below marks the livestreamed sessions.
    </p>
    {%- endif -%}
  </div>
</section>

