<header class="page-header">
  <div class="container">
    <span class="eyebrow">About</span>
    <h1>The People</h1>
    <p class="page-lead">
      Our Board members advise and steer the organisation, notably through thematic Working Groups (WG).
      A small support team handles day-to-day operations.
    </p>
  </div>
</header>

{# Three sections, all using the same card size + grid. Splitting
   Leadership out brings tiered roles (Founding Director / Treasurer /
   Secretary-General) into a focal block at the top instead of being
   absorbed into a 19-person flat grid. Card mark-up below is shared
   via the `person-card.njk` partial. #}

{%- if boardSorted.leadership and boardSorted.leadership.length %}
<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Leadership</h2>
    <div class="people-grid">
      {%- for person in boardSorted.leadership %}
        {%- include "person-card.njk" %}
      {%- endfor %}
    </div>
  </div>
</section>
{%- endif %}

<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Board Members</h2>
    <div class="people-grid">
      {%- for person in boardSorted.boardMembers %}
        {%- include "person-card.njk" %}
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Support Staff</h2>
    <div class="people-grid">
      {%- for person in boardSorted.support %}
        {%- set isSupport = true %}
        {%- include "person-card.njk" %}
      {%- endfor %}
    </div>
  </div>
</section>
