<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Event formats</h2>
    <div class="tile-grid" style="grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));">
      <article class="tile">
        <div class="tile-icon" aria-hidden="true">{{ icon("users-round") }}</div>
        <h2>Roundtables &amp; Conferences</h2>
        <p>
          Online and hybrid events with guests from academia and the policy world on critical
          issues in international security. Scholars and partners propose a topic, assemble a
          panel, and EISS provides the platform.
        </p>
      </article>

      <article class="tile">
        <div class="tile-icon" aria-hidden="true">{{ icon("graduation-cap") }}</div>
        <h2>Early-career seminars</h2>
        <p>
          Online and hybrid seminars organised by PhD students and early-career researchers to
          share their work and exchange ideas with the wider European security studies community.
        </p>
      </article>

      <article class="tile">
        <div class="tile-icon" aria-hidden="true">{{ icon("book-open") }}</div>
        <h2>Doctoral training workshops</h2>
        <p>
          Workshops tailored for PhD students and early-career researchers, covering the academic
          job market, publication strategy, navigating peer review, and turning a thesis into a
          book. Proposals welcome from both early-career and senior scholars.
        </p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <article class="card" style="padding: clamp(var(--space-6), 2vw + 1rem, var(--space-8));">
      <div class="featured-eyebrow">Propose an event</div>
      <h2>Have an event in mind?</h2>
      <p class="lead">
        We host roundtables, seminars, and workshops on a rolling basis. If you'd like to propose
        an event in one of the three formats above, get in touch. We'll work out the format and
        timing together.
      </p>
      <p style="margin-top: var(--space-5);">
        <a class="btn btn-primary" href="mailto:{{ site.contactEmail }}">
          {{ icon("mail") }} {{ site.contactEmail }}
        </a>
      </p>
    </article>
  </div>
</section>
