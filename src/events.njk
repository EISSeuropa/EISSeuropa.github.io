{% from "icons.njk" import icon %}

<header class="page-header">
  <div class="container">
    <span class="eyebrow">What we do</span>
    <h1>Events</h1>
    <p class="page-lead">
      Beyond the Annual Conference, EISS runs multi-year research programmes and hosts a regular
      calendar of network events — roundtables, seminars, and workshops — open to anyone working
      in European security studies.
    </p>
  </div>
</header>

<section class="section" aria-labelledby="programmes-heading">
  <div class="container">
    <h2 id="programmes-heading" style="margin-bottom: var(--space-5);">Programmes &amp; activities</h2>
    <div class="tile-grid" style="grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));">

      <article class="tile">
        <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">COST Action · 2025 - 2029</div>
        <h3>NetSec — Networking European Security Knowledge</h3>
        <p>
          A four-year COST Action that EISS launched together with a dozen institutions across
          Europe to address the fragmentation of the continent's intellectual and analytical base
          in security studies. Watch for policy workshops, summer schools, and conferences.
        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-primary btn-sm stretched-link" href="https://netsec-cost.eu/" target="_blank" rel="noopener">
            Visit netsec-cost.eu
          </a>
        </p>
      </article>

      <article class="tile">
        <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">Annual summer school</div>
        <h3>NetSec Early-Career Scholars Summer School</h3>
        <p>
          A residential summer school for PhD students and early-career researchers working at the
          intersection of security studies, strategic studies, and international relations.
        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-secondary btn-sm stretched-link" href="/NetSecSchool.html">Learn more about the Summer School</a>
        </p>
      </article>

      <article class="tile">
        <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">Multidisciplinary programme</div>
        <h3>Coercive Statecraft</h3>
        <p>
          A research programme on the use of coercive instruments (sanctions, threats, hybrid
          measures) in contemporary statecraft, gathering scholars and practitioners.
        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-secondary btn-sm stretched-link" href="/coercion.html">Learn more about Coercive Statecraft</a>
        </p>
      </article>

      <article class="tile">
        <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">Joint summer school</div>
        <h3>Euro-SWAMOS</h3>
        <p>
          The European Summer Workshop on the Analysis of Military Operations and Strategy, a
          partnership programme bringing together advanced students of strategy.
        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-secondary btn-sm stretched-link" href="/euroswamos.html">Learn more about Euro-SWAMOS</a>
        </p>
      </article>

      <article class="tile">
        <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">Survey · Results</div>
        <h3>Global Risks to the EU</h3>
        <p>
          A periodic expert survey on the global risks European security analysts consider most
          consequential for the EU, and the responses they recommend.
        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-secondary btn-sm stretched-link" href="/GlobalRisks.html">See the results</a>
        </p>
      </article>

      <article class="tile">
        <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">Joint conference · June 2024</div>
        <h3>Sciences Po–EISS Conference</h3>
        <p>
          A conference co-organised with the Center for International Studies (CERI) at Sciences Po.
          The June 2024 edition, "Origins of War and Diplomacy", gathered scholars across
          palaeoanthropology, archaeology, primatology, linguistics and political science in Paris.
        </p>
        <p style="margin-top: var(--space-4);">
          <a class="btn btn-secondary btn-sm stretched-link" href="/joint-2024.html">See the 2024 programme</a>
        </p>
      </article>

    </div>
  </div>
</section>

<section class="section" aria-labelledby="network-events-heading">
  <div class="container">
    <h2 id="network-events-heading" style="margin-bottom: var(--space-3);">Network events</h2>
    <p class="page-lead" style="margin-bottom: var(--space-5);">
      Online and hybrid events organised by EISS, the COST Action <a href="https://netsec-cost.eu/" target="_blank" rel="noopener">NetSec</a>, and partner institutions. Free and open to anyone working in or alongside European security studies. No membership required.
    </p>

{# Auto-synced upcoming events from indico.eiss-europa.com — full list,
   no limit. When the synced list is empty (see src/_data/indico.json)
   the partial renders an empty-state placeholder rather than disappearing
   — opt in via showEmptyState. #}
{% set limit = null %}
{% set showEmptyState = true %}
{% include "indico-events-list.njk" %}

{# Past members' events, below the upcoming list (hand-maintained data in
   src/_data/pastEvents.js; automation tracked in issue #401). #}
{% include "past-events-list.njk" %}

    <h3 style="margin-bottom: var(--space-5);">Event formats</h3>
    <div class="tile-grid" style="grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));">
      <article class="tile">
        <div class="tile-icon" aria-hidden="true">{{ icon("users-round") }}</div>
        <h4>Roundtables &amp; Conferences</h4>
        <p>
          Online and hybrid events with guests from academia and the policy world on critical
          issues in international security. Scholars and partners propose a topic, assemble a
          panel, and EISS provides the platform.
        </p>
      </article>

      <article class="tile">
        <div class="tile-icon" aria-hidden="true">{{ icon("graduation-cap") }}</div>
        <h4>Early-career seminars</h4>
        <p>
          Online and hybrid seminars organised by PhD students and early-career researchers to
          share their work and exchange ideas with the wider European security studies community.
        </p>
      </article>

      <article class="tile">
        <div class="tile-icon" aria-hidden="true">{{ icon("book-open") }}</div>
        <h4>Doctoral training workshops</h4>
        <p>
          Workshops tailored for PhD students and early-career researchers, covering the academic
          job market, publication strategy, navigating peer review, and turning a thesis into a
          book. Proposals welcome from both early-career and senior scholars.
        </p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <article class="card" style="padding: clamp(var(--space-6), 2vw + 1rem, var(--space-8));">
      <div class="featured-eyebrow">Propose an event</div>
      <h2>Have an event in mind?</h2>
      <p class="lead">
        We host roundtables, seminars, and workshops on a rolling basis. If you'd like to propose
        an event in one of the three formats above, get in touch. We'll work out the format and
        timing together.
      </p>
      <p style="margin-top: var(--space-5);">
        <a class="btn btn-primary" href="mailto:{{ site.contactEmail }}">
          {{ icon("mail") }} {{ site.contactEmail }}
        </a>
      </p>
    </article>
  </div>
</section>
