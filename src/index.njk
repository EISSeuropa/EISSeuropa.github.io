{# Featured card: the next-upcoming (or currently-running) conference,
   chosen from src/_data/conferences.js based on today's date. The card
   disappears entirely if there's no upcoming conference. #}
{% set conf = conferences.next %}
{% if conf %}
<section class="section" aria-labelledby="featured-title">
  <div class="container">
    <article class="card featured">
      <div>
        <div class="featured-eyebrow">Next conference</div>
        <h2 id="featured-title">European Security Studies Conference {{ conf.year }}</h2>
        {% set year = conf.year %}
        {% include "countdown.njk" %}
        <p class="featured-orgs">
          {{ conf.organisers.en }}
        </p>
        <div class="featured-meta">
          <div>
            <strong>{{ icon("calendar", "icon-inline") }}Dates</strong>
            {{ conf.dates.en }}
          </div>
          <div>
            <strong>{{ icon("map-pin", "icon-inline") }}Venue</strong>
            {{ conf.venue.en }}
          </div>
        </div>
        <div class="featured-registration">
          {# While the conference is current, the Livestream pill is the call
             to action, so suppress the badge's "View on Indico" CTA (it would
             otherwise sit redundantly beside the livestream link). #}
          {%- set hideBadgeCta = conf.livestreamUrl and conf.endDate >= conferences.today -%}
          {% include "registration-badge.njk" %}
          {%- if conf.livestreamUrl and conf.endDate >= conferences.today %}
          <a class="programme-live-tag" href="{{ conf.livestreamUrl }}" target="_blank" rel="noopener">{{ icon("video") }} Livestream {{ icon("external-link") }}</a>
          {%- endif %}
        </div>
        <div>
          <a class="btn btn-primary" href="/{{ conf.slug }}.html">Learn more about ESSC&nbsp;{{ conf.year }} {{ icon("arrow-right") }}</a>
        </div>
      </div>
      <aside class="featured-date" aria-hidden="true">
        <div class="month">{{ conf.monthLabel.en }}</div>
        <div class="day">{{ conf.dayRange | replace("–", "<span aria-hidden='true'>–</span>") | safe }}</div>
        <div class="year">{{ conf.year }} · {{ conf.city }}</div>
      </aside>
    </article>
  </div>
</section>
{% endif %}

{# Auto-synced upcoming events from indico.eiss-europa.com. Hides entirely
   when src/_data/indico.json has no upcoming entries. Limit to 5 on the
   homepage so the page doesn't grow unboundedly. #}
{% set limit = 5 %}
{% include "indico-events-list.njk" %}

{# Announcement card. Content lives in src/_data/announcement.js — edit
   there to rotate the news item. Flip `visible: false` to hide. #}
{% include "announcement-card.njk" %}

{# Conference Navigator entry point: stats-backed link into the ESSC corpus. #}
{% include "navigator-promo.njk" %}

<section class="section" aria-labelledby="join-title">
