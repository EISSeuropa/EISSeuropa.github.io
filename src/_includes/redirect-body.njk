<header class="page-header">
  <div class="container">
    <span class="eyebrow">Page moved</span>
    <h1>{{ title }}</h1>
    <p class="page-lead">
      This page has moved. You'll be taken to
      <strong>{{ redirectLabel }}</strong> in a moment.
    </p>
  </div>
</header>

<section class="section">
  <div class="container">
    <article class="card" style="padding: clamp(var(--space-6), 2vw + 1rem, var(--space-7)); text-align: center;">
      <p class="muted" style="margin-bottom: var(--space-5);">
        Not redirected automatically?
      </p>
      <p>
        <a class="btn btn-primary" href="{{ redirectTo }}">
          Go to {{ redirectLabel }}
        </a>
      </p>
    </article>
  </div>
</section>
