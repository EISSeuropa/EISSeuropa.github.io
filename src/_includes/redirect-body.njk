<header class="page-header">
  <div class="container">
    <span class="eyebrow">Page moved</span>
    <h1>{{ title }}</h1>
    <p class="page-lead">
      This page has moved. You'll be taken to
      <strong>{{ redirectLabel }}</strong> in a moment.
    </p>
  </div>
</header>

<section class="section">
  <div class="container">
    <article class="card" style="padding: clamp(var(--space-6), 2vw + 1rem, var(--space-7)); text-align: center;">
      <p class="muted" style="margin-bottom: var(--space-5);">
        Not redirected automatically?
      </p>
      <p>
        <a class="btn btn-primary" href="{{ redirectTo }}">
          Go to {{ redirectLabel }}
        </a>
      </p>
    </article>
  </div>
</section>

{%- if redirectPreserveQuery %}
{# Instant client-side redirect that PRESERVES the query string and hash (the
   <head> meta-refresh is the no-JS fallback but can only hit the bare target).
   Used by the Anthology moves (/speakers, /papers → /anthology) so old links
   like ?person=, ?year= and #paper-<slug> still land in the right place.
   redirectForceView pins the view (the /papers move opens the by-paper view). #}
<script>
(function () {
  var u = new URL("{{ redirectTo }}", location.origin);
  new URLSearchParams(location.search).forEach(function (v, k) { u.searchParams.set(k, v); });
  {% if redirectForceView %}u.searchParams.set("view", "{{ redirectForceView }}");{% endif %}
  u.hash = location.hash;
  location.replace(u.pathname + u.search + u.hash);
}());
</script>
{%- endif %}
