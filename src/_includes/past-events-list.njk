{# Past members' events section for /events, sitting below the auto-synced
   Upcoming Events. Data is hand-maintained in src/_data/pastEvents.js
   (the Indico "Members' Events" category is members-only and not on the
   public export API; automating this is tracked in issue #401).

   Reuses the .indico-event* visual language of the upcoming-events list.
   Most rows are members-only on Indico and so are NOT links (a public
   visitor would hit a login wall); a row links out only when its entry
   carries an `href` to a public page (the .indico-event--static modifier
   styles the non-linked rows).

   Variables in scope from the page template:
     - `lang` — front-matter, defaults to "en"
     - `pastEvents` — the data file (newest first)
#}
{% from "icons.njk" import icon %}
{%- set _lang = lang or "en" -%}
{%- set t = i18n[_lang] -%}

{# Date chip + title + meta (conveners with affiliations, then category
   tag). Event titles are English on every locale, so marked lang="en". #}
{%- macro eventBody(ev) -%}
  {%- set _hasPeople = ev.presenters and ev.presenters.length -%}
  <span class="indico-event-date" aria-hidden="true">{{ icon("calendar") }} {{ ev.date }}</span>
  <span class="indico-event-body">
    <strong lang="en">{{ ev.title }}</strong>
    {%- if _hasPeople or ev.tag %}
    <span class="indico-event-meta">
      {%- for p in ev.presenters -%}
        <span lang="en">{{ p.name }}{% if p.affiliation %} ({{ p.affiliation }}){% endif %}</span>{% if not loop.last %}, {% endif %}
      {%- endfor -%}
      {%- if _hasPeople and ev.tag %} · {% endif -%}
      {%- if ev.tag %}{{ ev.tag }}{% endif -%}
    </span>
    {%- endif %}
  </span>
{%- endmacro -%}

{% if pastEvents and pastEvents.length %}
<section class="section-tight indico-events" aria-labelledby="past-events-title">
  <div class="container">
    <div class="featured-eyebrow" style="margin-bottom: var(--space-3);">{{ t.pastEvents.sectionEyebrow }}</div>
    <h2 id="past-events-title">{{ t.pastEvents.sectionHeading }}</h2>
    <p class="muted" style="max-width: 44rem; margin-bottom: var(--space-5);">
      {{ t.pastEvents.sectionLead }}
    </p>

    <ul class="indico-events-list" role="list">
      {%- for ev in pastEvents %}
      <li class="indico-event-row">
        {%- if ev.href %}
        <a class="indico-event" href="{{ ev.href }}">
          {{ eventBody(ev) }}
          <span class="indico-event-arrow" aria-hidden="true">{{ icon("arrow-right") }}</span>
        </a>
        {%- else %}
        <div class="indico-event indico-event--static">
          {{ eventBody(ev) }}
        </div>
        {%- endif %}
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
{% endif %}
