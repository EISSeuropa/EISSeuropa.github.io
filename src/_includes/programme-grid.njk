{# Live programme grid for annual conference pages.
   Renders nothing when the year has no programme data in
   indico.annualConferences[year].programme.days.

   Variables in scope from the page template:
     - `lang` — front-matter, defaults to "en"
     - `year` — string, e.g. "2026"
     - `indico` — src/_data/indico.json (data file)
     - `conferences` — src/_data/conferences.js

   Data shape produced by scripts/sync-indico.py:extract_programme:
     programme.days[].rows[] = [
       { startTime, endTime, parallel: bool, items: [slot, …] }, …
     ]
   A `row` is one time block. When `parallel` is true the items grid
   renders side-by-side (typically two concurrent panels in different
   rooms); when false the single item takes the full content width.

   Slot shapes:
     - kind="session"     : sessionCode, subtype ("roundtable" |
                            "plenary" | null), conveners, discussants,
                            contributions
     - kind="contribution": standalone — speakers, abstract
     - kind="break"       : title only, rendered quietly

   Design rationale lives at docs/indico-programme-integration.md.
#}
{% from "icons.njk" import icon %}
{%- set _lang = lang or "en" -%}
{%- set t = i18n[_lang] -%}
{%- set _conf = indico.annualConferences[year] -%}
{%- set _programme = _conf.programme if _conf else null -%}
{# Conference-level livestream link (one Zoom webinar reused for every
   session), from conferences.js. Gated to the current edition
   (endDate >= today) so it disappears once the conference is over.
   Every "Livestream" pill below, in the signpost and on each streamed
   session, becomes a link to it. #}
{%- set _confMeta = conferences.byYear[year] -%}
{%- set _liveUrl = _confMeta.livestreamUrl if (_confMeta and _confMeta.livestreamUrl and _confMeta.endDate >= conferences.today) else null -%}

{% if _programme and _programme.days and _programme.days.length %}
<section class="section programme" id="programme" aria-labelledby="programme-title">
  <div class="container">
    <div class="featured-eyebrow">{{ t.programme.eyebrow }}</div>
    <h2 id="programme-title">{{ t.programme.heading }}</h2>
    <p class="muted" style="max-width: 44rem; margin-bottom: var(--space-4);">
      {{ t.programme.lead }}
    </p>

    {# Early signpost to the livestreamed sessions, in place of the old
       dedicated "Livestreamed sessions" block. Shown only when the year
       has sessions tagged for livestream. #}
    {%- if _conf.livestreamed and _conf.livestreamed.length %}
    {%- set _signpostUrl = _liveUrl or _conf.url -%}
    <p class="programme-livestream-note">
      {%- if _signpostUrl %}
      <a class="programme-live-tag" href="{{ _signpostUrl }}" target="_blank" rel="noopener">{{ icon("video") }} {{ t.programme.livestreamPill }} {{ icon("external-link") }}</a>
      {%- else %}
      <span class="programme-live-tag">{{ icon("video") }} {{ t.programme.livestreamPill }}</span>
      {%- endif %}
      {{ t.programme.livestreamNote }}
    </p>
    {%- endif %}

    {%- if _programme.days.length > 1 %}
    <nav class="programme-days" aria-label="{{ t.programme.daysNav }}">
      {%- for day in _programme.days %}
      <a class="programme-day-chip" href="#day-{{ day.date }}">
        {{ day.label }} <span class="muted">· {{ day.date }}</span>
      </a>
      {%- endfor %}
    </nav>
    {%- endif %}

    {# Per-paper deep-link anchors (#676 / #738), emitted once per slug so the
       Anthology by-paper / by-person views can link to a paper's exact slot.
       Same `paperAnchor` filter as archive-programme.njk, so the live editions
       resolve identically to the archived ones. #}
    {%- set _seenPapers = [] -%}
    {%- for day in _programme.days %}
    <div class="programme-day" id="day-{{ day.date }}">
      <h3 class="programme-day-title">{{ day.label }} <span class="muted">— {{ day.date }}</span></h3>

      <ol class="programme-rows" role="list">
        {%- for row in day.rows %}
        <li class="programme-row{% if row.parallel %} programme-row--parallel{% endif %}">
          <div class="programme-when">
            <span class="programme-when-time">{{ row.startTime }}<span aria-hidden="true">–</span><span class="sr-only"> to </span>{{ row.endTime }}</span>
          </div>

          <div class="programme-row-items">
            {%- for slot in row.items %}
            <article class="programme-slot programme-slot--{{ slot.kind }}{% if slot.subtype %} programme-slot--{{ slot.subtype }}{% endif %}">

              {%- if slot.kind == "break" %}
              <p class="programme-break-title" lang="en">{{ slot.title }}</p>
              {%- if slot.room %}
              <p class="programme-slot-meta programme-slot-room programme-slot-room--c{{ slot.roomColorIndex if slot.roomColorIndex is not none else 'x' }}">
                {{ icon("map-pin") }} {{ slot.room }}
              </p>
              {%- endif %}

              {%- elif slot.kind == "session" %}
              <p class="programme-slot-title" lang="en">
                {%- if slot.url -%}
                <a href="{{ slot.url }}" target="_blank" rel="noopener">{{ slot.title }}</a>
                {%- else -%}
                {{ slot.title }}
                {%- endif -%}
              </p>
              {%- if slot.slotTitle and slot.slotTitle != slot.title %}
              <p class="programme-slot-subtitle muted" lang="en">{{ slot.slotTitle }}</p>
              {%- endif %}
              {%- if slot.room %}
              <p class="programme-slot-meta programme-slot-room programme-slot-room--c{{ slot.roomColorIndex if slot.roomColorIndex is not none else 'x' }}">
                {{ icon("map-pin") }} {{ slot.room }}
              </p>
              {%- endif %}
              {%- if slot.livestreamed %}
              {%- if _liveUrl %}
              <a class="programme-slot-meta programme-slot-live" href="{{ _liveUrl }}" target="_blank" rel="noopener">{{ icon("video") }} {{ t.programme.livestreamPill }} {{ icon("external-link") }}</a>
              {%- else %}
              <p class="programme-slot-meta programme-slot-live">{{ icon("video") }} {{ t.programme.livestreamPill }}</p>
              {%- endif %}
              {%- endif %}
              {%- if slot.conveners and slot.conveners.length %}
              <p class="programme-slot-meta">
                <strong>{{ t.programme.chairedBy }}:</strong>
<span lang="en">
                {%- for c in slot.conveners -%}
                  {{ c.name }}{% if c.affiliation %} <span class="muted">({{ c.affiliation }})</span>{% endif %}{% if not loop.last %}, {% endif %}
                {%- endfor -%}</span>
              </p>
              {%- endif %}

              {%- if slot.discussants and slot.discussants.length %}
              {# Roundtables: discussants inline; no expander
                 because there are no papers to reveal. #}
              <p class="programme-slot-meta">
                <strong>{{ t.programme.discussants }}:</strong>
<span lang="en">
                {%- for p in slot.discussants -%}
                  {{ p.name }}{% if p.affiliation %} <span class="muted">({{ p.affiliation }})</span>{% endif %}{% if not loop.last %}, {% endif %}
                {%- endfor -%}</span>
              </p>
              {%- endif %}

              {%- if slot.contributions and slot.contributions.length %}
              <details class="programme-contribs">
                <summary>{{ t.programme.showContributions }} <span class="muted">({{ slot.contributions.length }})</span></summary>
                <ol class="programme-contrib-list" role="list">
                  {%- for c in slot.contributions %}
                  {%- set _pslug = c.title | paperAnchor -%}
                  {%- set _panchor = _pslug and (_pslug not in _seenPapers) -%}
                  {%- if _panchor %}{% set _ = _seenPapers.push(_pslug) %}{% endif -%}
                  <li class="programme-contrib"{% if _panchor %} id="paper-{{ _pslug }}"{% endif %}>
                    <div class="programme-contrib-when" aria-hidden="true">
                      {{ c.startTime }}
                    </div>
                    <div>
                      <p class="programme-contrib-title" lang="en">
                        {%- if c.url -%}
                        <a href="{{ c.url }}" target="_blank" rel="noopener">{{ c.title }}</a>
                        {%- else -%}
                        {{ c.title }}
                        {%- endif -%}
                      </p>
                      {%- if c.authors and c.authors.length %}
                      <p class="programme-contrib-speakers muted">
                        {%- for a in c.authors -%}
                          <span class="programme-author{% if a.isSpeaker %} programme-author--speaker{% endif %}">
                            {%- if a.isSpeaker %}<span class="programme-author-mic" title="{{ t.programme.presenter }}">{{ icon("mic") }}</span><span class="sr-only">{{ t.programme.presenter }}: </span>{% endif -%}
                            <span lang="en">{{ a.name }}{% if a.affiliation %} <em>({{ a.affiliation }})</em>{% endif %}</span></span>{% if not loop.last %} · {% endif %}
                        {%- endfor -%}
                      </p>
                      {%- elif c.speakers and c.speakers.length %}
                      <p class="programme-contrib-speakers muted">
<span lang="en">
                        {%- for sp in c.speakers -%}
                          {{ sp.name }}{% if sp.affiliation %} <em>({{ sp.affiliation }})</em>{% endif %}{% if not loop.last %} · {% endif %}
                        {%- endfor -%}</span>
                      </p>
                      {%- endif %}
                      {%- if c.abstract %}
                      <p class="programme-contrib-abstract">{{ c.abstract }}
                      {%- if c.hasFullAbstract -%}
                        {% if c.url %} <a href="{{ c.url }}" target="_blank" rel="noopener">{{ t.programme.readFullAbstract }}</a>{% endif %}
                      {%- endif -%}
                      </p>
                      {%- endif %}
                    </div>
                  </li>
                  {%- endfor %}
                </ol>
              </details>
              {%- endif %}

              {%- elif slot.kind == "contribution" %}
              <p class="programme-slot-title" lang="en">
                {%- if slot.url -%}
                <a href="{{ slot.url }}" target="_blank" rel="noopener">{{ slot.title }}</a>
                {%- else -%}
                {{ slot.title }}
                {%- endif -%}
              </p>
              {%- if slot.speakers and slot.speakers.length %}
              <p class="programme-slot-meta">
<span lang="en">
                {%- for sp in slot.speakers -%}
                  {{ sp.name }}{% if sp.affiliation %} <span class="muted">({{ sp.affiliation }})</span>{% endif %}{% if not loop.last %} · {% endif %}
                {%- endfor -%}</span>
              </p>
              {%- endif %}
              {# Panel-level (session) abstracts are intentionally not shown:
                 only some panels carry one, so rendering them made the
                 programme look uneven. Hidden for consistency (#903). The
                 per-paper contribution abstracts above are unaffected. #}
              {%- endif %}

            </article>
            {%- endfor %}
          </div>
        </li>
        {%- endfor %}
      </ol>
    </div>
    {%- endfor %}

    {% include "speakers-signpost.njk" %}
    <p class="muted programme-footnote" style="margin-top: var(--space-4); font-size: var(--fs-sm);">
      {{ t.programme.sourceNote }}
      <a href="https://indico.eiss-europa.com/event/{{ _conf.id }}/" target="_blank" rel="noopener">
        {{ t.programme.viewOnIndico }} {{ icon("external-link") }}
      </a>
    </p>
  </div>
</section>
{% endif %}
