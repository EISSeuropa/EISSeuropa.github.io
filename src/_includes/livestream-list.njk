{# Live-from-Indico livestreamed-sessions block for annual conference
   pages. Renders nothing when the year has no sessions tagged for
   livestream (no entries in indico.annualConferences[year].livestreamed).

   Variables in scope from the page template:
     - `lang` — front-matter, defaults to "en"
     - `year` — string, e.g. "2026"
     - `indico` — src/_data/indico.json. The sessions live at
                  indico.annualConferences[year].livestreamed (array).

   Each session object has the shape produced by
   scripts/sync-indico.py:extract_livestreamed:
     { type: "introduction" | "roundtable" | "keynote" | "conclusion",
       title, startDate, startTime, endTime, location, room, url,
       conveners: [{name, affiliation}], videoUrl }

   When `videoUrl` is null we render an "Online room TBA" placeholder —
   the moment Indico publishes the join link, the next sync swaps the
   placeholder for a real "Join online" button.

   The wrapper / row classnames (.keynote, .keynote-*) are kept from
   v2.7-v2.8 for styling continuity; semantically they cover all
   livestreamed session types.
#}
{% from "icons.njk" import icon %}
{%- set _lang = lang or "en" -%}
{%- set t = i18n[_lang] -%}
{%- set _conf = indico.annualConferences[year] -%}
{%- set _sessions = _conf.livestreamed if _conf else [] -%}

{% if _sessions and _sessions.length %}
<section class="section-tight keynotes" aria-labelledby="livestream-title">
  <div class="container">
    <div class="featured-eyebrow">{{ t.livestream.sectionEyebrow }}</div>
    <h2 id="livestream-title">{{ t.livestream.sectionHeading }}</h2>
    <p class="muted" style="max-width: 44rem; margin-bottom: var(--space-5);">
      {{ t.livestream.sectionLead }}
    </p>

    <ul class="keynotes-list" role="list">
      {%- for k in _sessions %}
      <li class="keynote keynote--{{ k.type }}">
        <div class="keynote-when" aria-hidden="true">
          {{ icon("calendar") }}
          <span class="keynote-when-date">{{ k.startDate }}</span>
          <span class="keynote-when-time">{{ k.startTime }} – {{ k.endTime }}</span>
        </div>
        <div class="keynote-body">
          <p class="keynote-type">{{ t.livestream.types[k.type] }}</p>
          <p class="keynote-title">
            <a href="{{ k.url }}" target="_blank" rel="noopener">{{ k.title }}</a>
          </p>
          {%- if k.conveners and k.conveners.length %}
          <p class="keynote-conveners muted">
            {%- for c in k.conveners -%}
              {{ c.name }}{% if c.affiliation %} <em>({{ c.affiliation }})</em>{% endif %}{% if not loop.last %} · {% endif %}
            {%- endfor -%}
          </p>
          {%- endif %}
          <p class="keynote-meta muted">
            {{ icon("map-pin") }} {{ k.location }}{% if k.room %} — {{ k.room }}{% endif %}
          </p>
        </div>
        <div class="keynote-action">
          {%- if k.videoUrl %}
          <a class="btn btn-primary btn-sm" href="{{ k.videoUrl }}" target="_blank" rel="noopener">
            {{ icon("video") }} {{ t.livestream.joinOnline }}
          </a>
          {%- else %}
          <span class="keynote-tba">
            {{ icon("video-off") }} {{ t.livestream.onlineRoomTba }}
          </span>
          {%- endif %}
        </div>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
{% endif %}
