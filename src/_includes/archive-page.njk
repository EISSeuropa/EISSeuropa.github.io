{# Conference Navigator — the unified archive over the ESSC corpus (#756).
   One surface, two lenses: a by-person view (speakers-index.njk) and a
   by-paper view (papers-page.njk), both rendering from corpus.js /
   paperIndex.js. The wrapper page sets `archiveDefaultView` ("people" or
   "papers"): /speakers.html defaults to people, /papers.html to papers, and
   both URLs stay live (no link breaks, one include = no drift). archive.js
   toggles the panels and mirrors the choice in ?view=. The non-default panel
   is server-rendered (so the toggle has content) but carries
   data-pagefind-ignore, so each URL contributes only its own view to the
   site search rather than indexing both lists twice. #}
{% from "icons.njk" import icon %}
{%- set t = i18n[lang or "en"] -%}
{%- set n18n = t.navigator -%}
{%- set defaultView = archiveDefaultView or "people" -%}
{%- set coverageTip = n18n.coverageTip | replace("{a}", paperIndex.stats.abstractCount) | replace("{b}", paperIndex.stats.eligiblePaperCount) -%}

<header class="page-header">
  <div class="container">
    <span class="eyebrow">{{ n18n.eyebrow }}</span>
    <h1>{{ n18n.title }}</h1>
    <p class="page-lead">{{ n18n.lead }}</p>
    <dl class="stats-row" aria-label="{{ n18n.eyebrow }}">
      <div class="stat">
        <dt>{{ corpus.stats.speakerCount }}</dt>
        <dd>{{ t.speakers.statSpeakers }}</dd>
      </div>
      <div class="stat">
        <dt>{{ corpus.stats.editions }}</dt>
        <dd>{{ t.speakers.statConferences }} <span class="muted">{{ t.speakers.statConferencesSince }}</span></dd>
      </div>
      <div class="stat">
        {# Deduplicated paper count (paperIndex), so the headline matches the
           by-paper list and its filter dropdowns. corpus.stats.paperCount is
           the raw per-contribution total and double-counts the few papers that
           appear twice in the programmes (e.g. a poster shown on both days). #}
        <dt>{{ paperIndex.stats.paperCount }}</dt>
        <dd>{{ t.speakers.statPapers }}</dd>
      </div>
      <div class="stat">
        <dt>{{ paperIndex.stats.abstractCount }}<span class="coverage-tip" tabindex="0" data-tooltip="{{ coverageTip }}" title="{{ coverageTip }}" aria-label="{{ coverageTip }}">{{ icon("info") }}</span></dt>
        <dd>{{ n18n.statAbstracts }}</dd>
      </div>
    </dl>

    {# Per-year abstract coverage, collapsed by default (native <details>, no
       JS). Bars render from paperIndex.years; coverage = abstracts on file /
       papers eligible for one. #}
    <details class="coverage-detail">
      <summary>{{ n18n.coverageSummary }}</summary>
      <div class="coverage-bars">
        {%- for y in paperIndex.years %}
        <div class="coverage-row">
          <span class="coverage-year">{{ y.year }}</span>
          <span class="coverage-track"><span class="coverage-fill" style="width: {{ y.coverage }}%"></span></span>
          <span class="coverage-count">{{ y.withAbstract }}<span class="coverage-of">/{{ y.eligible }}</span></span>
          <span class="coverage-pct">{{ y.coverage }}%</span>
        </div>
        {%- endfor %}
      </div>
      <p class="coverage-note">{{ n18n.coverageNote }}</p>
    </details>
  </div>
</header>

<section class="section">
  <div class="container">

    {# Module-level early-access notice. One element, every locale, via the
       navigator i18n catalog; the FR/DE bodies also flag that the individual
       paper pages are English-only. #}
    <aside class="anthology-notice" role="note">
      <span class="anthology-notice-badge">{{ n18n.earlyAccessBadge }}</span>
      <p class="anthology-notice-text">{{ n18n.earlyAccessBody }} <a href="mailto:{{ site.contactEmail }}?subject=Anthology">{{ n18n.earlyAccessCta }}</a></p>
    </aside>

    <div class="archive-toggle" role="tablist" aria-label="{{ n18n.title }}">
      <button type="button" role="tab" class="archive-tab" data-archive-tab="people"
              id="archive-tab-people" aria-controls="archive-panel-people"
              aria-selected="{{ 'true' if defaultView == 'people' else 'false' }}">{{ n18n.byPerson }}</button>
      <button type="button" role="tab" class="archive-tab" data-archive-tab="papers"
              id="archive-tab-papers" aria-controls="archive-panel-papers"
              aria-selected="{{ 'true' if defaultView == 'papers' else 'false' }}">{{ n18n.byPaper }}</button>
    </div>

    <div class="archive-panel" id="archive-panel-people" role="tabpanel"
         aria-labelledby="archive-tab-people" data-archive-panel="people"
         {%- if defaultView != 'people' %} hidden data-pagefind-ignore{% endif %}>
      {% include "speakers-index.njk" %}
    </div>

    <div class="archive-panel" id="archive-panel-papers" role="tabpanel"
         aria-labelledby="archive-tab-papers" data-archive-panel="papers"
         {%- if defaultView != 'papers' %} hidden data-pagefind-ignore{% endif %}>
      {% include "papers-page.njk" %}
    </div>

    {# Wayfinding to the Anthology Atlas — the force-directed map of the same
       corpus. Shown under both views (the atlas visualises people and papers
       alike), in every locale, so /anthology and /papers reach it in ≤2
       clicks (#1134). data-pagefind-ignore: it's a nav affordance, not
       content, and it links to a page that indexes itself. #}
    <div data-pagefind-ignore>
      {% include "atlas-signpost.njk" %}
    </div>

  </div>
</section>

<script src="{{ '/assets/js/archive.js' | bust }}" defer></script>
