{# "Publications & outputs" section, folded onto /initiative from the retired
   /outputs page (#756 phase 3). Reuses the existing t.outputs.* chrome, so no
   re-translation. Only the network's own curated outputs live here now;
   members' personal publications moved to their profile pages
   (/board/<slug>). Included identically by the three /initiative locale files,
   so the drift checker stays clean. #}
{% from "icons.njk" import icon %}
{%- set t = i18n[lang or "en"] -%}
{%- set o = t.outputs -%}
<section class="section" id="outputs" aria-labelledby="outputs-title">
  <div class="container">
    <h2 id="outputs-title">{{ o.networkHeading }}</h2>
    <article class="prose">
      <p>{{ o.networkIntro }}</p>
      <p><a href="/GlobalRisks.html">{{ o.globalRisksLabel }} {{ icon("arrow-right") }}</a></p>
      {%- set _spk = "/anthology.html" if (lang or "en") == "en" else "/anthology." + lang + ".html" -%}
      <p><a href="{{ _spk }}">{{ t.navigator.initiativeLink }} {{ icon("arrow-right") }}</a></p>
    </article>

    {# One latest work per member (#718) as a teaser; the full grouped list is
       on /publications. Each member's works come newest-first from the ORCID
       sync, so works[0] is their most recent. Distinct from the curated network
       outputs above, and from the Anthology of EISS-conference papers. Sparse
       until more members add an ORCID iD; grows automatically. Titles, journals
       and names stay in their original language (lang="en"). #}
    {%- set _latest = [] -%}
    {%- for m in orcidWorks -%}
      {%- if m.works.length -%}
        {%- set w = m.works[0] -%}
        {%- set _ = _latest.push({ author: m.name, slug: m.slug, title: w.title, year: w.year, journal: w.journal, doi: w.doi }) -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if _latest.length %}
    <h3 id="member-publications" style="margin-top: var(--space-7);">{{ o.membersHeading }}</h3>
    <p class="muted" style="max-width: 46rem;">{{ o.membersIntro }}</p>
    <ul class="member-works" role="list">
      {%- for w in (_latest | sort(true, false, "year")) %}
      <li class="member-work">
        <span class="member-work-title" lang="en">{% if w.doi %}<a href="{{ w.doi | extLink }}" target="_blank" rel="noopener">{{ w.title }}</a>{% else %}{{ w.title }}{% endif %}</span>
        <span class="member-work-meta muted" lang="en"><a href="/board/{{ w.slug }}.html">{{ w.author }}</a>{% if w.journal %} &middot; {{ w.journal }}{% endif %}{% if w.year %} &middot; {{ w.year }}{% endif %}</span>
      </li>
      {%- endfor %}
    </ul>
    {%- set _pubs = "/publications.html" if (lang or "en") == "en" else "/publications." + lang + ".html" -%}
    <p style="margin-top: var(--space-4);"><a href="{{ _pubs }}">{{ o.membersAll }} {{ icon("arrow-right") }}</a></p>
    <p class="muted" style="font-size: var(--fs-xs); margin-top: var(--space-3); max-width: 46rem;">{{ o.sourceNote }}</p>
    {%- endif %}
  </div>
</section>
