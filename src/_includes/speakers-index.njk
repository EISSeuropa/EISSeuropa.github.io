{# By-person panel body of the Conference Navigator (#756). Rendered inside
   archive-page.njk's people panel, which provides the page header, the
   section/container wrapper and the view toggle. This file holds the
   speaker filters + A–Z nav + the speaker list, so the ~490-entry loop
   isn't triplicated across locales. All chrome is `t.speakers.*`; the data
   (corpus.speakers) is identical across locales, so names, paper titles,
   affiliations and theme labels stay in their original language
   (lang="en"). `speaker-filter.js` reads its live-region strings from the
   data-* attributes on [data-speaker-status] so the JS stays locale-agnostic. #}
{%- set t = i18n[lang or "en"] -%}
{%- set s18n = t.speakers -%}

<div class="speaker-filters" role="search">
  <div class="speaker-field speaker-field--search">
    <label class="speaker-field-label" for="speaker-find">{{ s18n.findLabel }}</label>
    <input id="speaker-find" type="search" data-speaker-find placeholder="{{ s18n.findPlaceholder }}" autocomplete="off">
  </div>
  <div class="speaker-field">
    <label class="speaker-field-label" for="speaker-theme">{{ s18n.themeLabel }}</label>
    <select id="speaker-theme" data-speaker-theme>
      <option value="">{{ s18n.allThemes }} ({{ corpus.stats.speakerCount }})</option>
      {%- for th in corpus.themes %}
      <option value="{{ th.key }}">{{ th.label[lang or "en"] or th.label.en }} ({{ th.count }})</option>
      {%- endfor %}
    </select>
  </div>
  <div class="speaker-field">
    <label class="speaker-field-label" for="speaker-event">{{ s18n.eventLabel }}</label>
    <select id="speaker-event" data-speaker-event>
      <option value="">{{ s18n.allEvents }}</option>
      {%- for e in corpus.editions %}
      <option value="{{ e.key }}">{{ e.display }} ({{ e.count }})</option>
      {%- endfor %}
    </select>
  </div>
  <button type="button" class="btn btn-sm speaker-clear" data-speaker-clear hidden>{{ s18n.clear }}</button>
</div>

<nav class="speaker-az" aria-label="{{ s18n.jumpToLetter }}">
  {%- for L in corpus.letters %}
  <a href="#ltr-{{ L }}">{{ L }}</a>
  {%- endfor %}
</nav>

{# Filter status, announced to assistive tech (role=status → polite live
   region). Empty when nothing is filtered. The data-msg-* strings are
   the localised templates speaker-filter.js fills in. #}
<p class="speaker-status" role="status" aria-live="polite" data-speaker-status hidden
   data-msg-none="{{ s18n.noMatch }}"
   data-msg-one="{{ s18n.resultsOne }}"
   data-msg-many="{{ s18n.resultsMany }}"
   data-msg-matching="{{ s18n.matching }}"></p>

<ol class="speaker-index" role="list" data-speaker-list>
  {%- for s in corpus.speakers %}
  {%- set prevLetter = corpus.speakers[loop.index0 - 1].letter if not loop.first else "" %}
  {%- if s.letter != prevLetter %}
  <li class="speaker-letter" role="presentation" data-speaker-letter="{{ s.letter }}">
    <h2 id="ltr-{{ s.letter }}" class="speaker-letter-h">{{ s.letter }}</h2>
  </li>
  {%- endif %}
  <li class="speaker-entry" data-speaker-entry data-name="{{ s.display }}" data-themes="{{ s.themes | join('|') }}" data-events="{{ s.editionKeys | join('|') }}">
    {%- if s.profileUrl %}
    <span class="speaker-headshot" aria-hidden="true">
      {%- if s.photo %}<img src="{{ s.photo }}" alt="" loading="lazy" width="48" height="48">
      {%- else %}<span class="speaker-headshot-ph">{{ s.initials }}</span>{% endif %}
    </span>
    {%- endif %}
    <div class="speaker-entry-body">
      <p class="speaker-name" lang="en">
        {%- if s.profileUrl %}<a href="{{ s.profileUrl }}">{{ s.display }}</a>
        {%- else %}{{ s.display }}{% endif %}
        {%- if s.profileUrl %} <span class="speaker-badge">{{ s18n.memberBadge }}</span>{% endif %}
      </p>
      {%- if s.affiliation %}
      <p class="speaker-aff muted" lang="en">{{ s.affiliation }}</p>
      {%- endif %}
      {%- if s.years.length %}
      <p class="speaker-years" aria-label="{{ s18n.attendedLabel }}">
        {%- for y in s.years %}<span class="speaker-year-pill">{{ y }}</span>{% endfor %}
      </p>
      {%- endif %}
      {%- if s.themes.length %}
      <p class="speaker-themes">
        {%- for th in s.themes %}<span class="speaker-theme-chip">{{ corpus.themeLabels[th][lang or "en"] or corpus.themeLabels[th].en }}</span>{% endfor %}
      </p>
      {%- endif %}
      <details class="speaker-papers">
        <summary>{{ s.count }} {{ s18n.contributionOne if s.count == 1 else s18n.contributionMany }}{% if s.firstYear %} · {{ s.firstYear }}{% if s.lastYear != s.firstYear %}–{{ s.lastYear }}{% endif %}{% endif %}</summary>
        <ul role="list">
          {%- for p in s.papers %}
          <li>
            <span class="speaker-paper-conf"><a href="{{ p.conferenceUrl }}">{{ p.conferenceLabel }}{% if p.year %} {{ p.year }}{% endif %}</a></span>
            <span class="speaker-paper-title" lang="en">{{ p.title }}</span>
          </li>
          {%- endfor %}
        </ul>
      </details>
    </div>
  </li>
  {%- endfor %}
</ol>

<p class="muted" style="margin-top: var(--space-6); font-size: var(--fs-sm); max-width: 44rem;">
  {{ s18n.note }}
</p>

<script src="{{ '/assets/js/speaker-filter.js' | bust }}" defer></script>
