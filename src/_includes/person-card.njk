{# Shared card mark-up for /board (Leadership / Board Members /
   Support Staff). Variables in scope:
     - person   — entry from boardSorted.leadership / .boardMembers /
                  .support. Contains the raw board.json fields plus
                  the computed `isEsscActive` boolean.
     - isSupport — true when rendering a support-staff card. Switches
                  the body text from `themes` (research themes) to
                  `bio` (longer-form prose). Defaults to false.

   Optional fields on `person` that change the rendering:
     - functionalResponsibility — a secondary role label (e.g.
       "Technology Coordinator") shown alongside the primary role.
       Used for Board Members who also hold a coordinator function.
     - isEsscActive — when true, a mic icon appears next to the role
       indicating the person is chairing, discussing, or speaking at
       the live ESSC edition. #}
{% from "icons.njk" import icon %}
{%- set isSupport = isSupport or false -%}
{%- set lang = lang or "en" -%}
{%- set t = i18n[lang] -%}

<article class="person"{% if person.slug %} id="{{ person.slug }}"{% endif %}>
  <img class="person-photo" src="{{ person.photo }}" alt="{{ person.alt or person.name }}" loading="lazy">
  <div class="person-body">
    <p class="person-role">
      <span class="person-role-primary">{{ person.role }}</span>
      {%- if person.functionalResponsibility %}
      <span class="person-role-sep" aria-hidden="true">·</span>
      <span class="person-functional-resp">{{ person.functionalResponsibility }}</span>
      {%- endif %}
      {%- if person.isEsscActive %}
      <span class="person-essc-speaker" title="{{ t.boardPage.esscSpeakerTitle }}" aria-label="{{ t.boardPage.esscSpeakerTitle }}">
        {{ icon("mic") }}
      </span>
      {%- endif %}
    </p>
    <p class="person-name">{{ person.name }}</p>
    {%- if isSupport %}
    <p class="person-affiliation">{{ person.bio | safe }}</p>
    {%- else %}
    <p class="person-affiliation">{{ person.affiliation | safe }}</p>
    {%- if person.themes %}
    <p class="person-affiliation muted" style="margin-top: var(--space-2); font-size: var(--fs-xs); border-top: 1px solid var(--border); padding-top: var(--space-2);"><strong>{{ t.boardPage.researchThemes }}:</strong> {{ person.themes | safe }}</p>
    {%- endif %}
    {%- endif %}
  </div>
</article>
