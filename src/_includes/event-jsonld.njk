{# schema.org Event JSON-LD for a conference page.

   Emits a <script type="application/ld+json"> Event block built from
   conferences.byYear[year or archiveSlug], so search engines can index
   conference metadata (dates, venue, organiser). Valid anywhere in the
   document; archive-programme.njk includes it near the top of the body
   for all /YYYY archive pages (#796).

   Requires `year` or `archiveSlug` (string) in scope. Renders nothing
   when the year has no conferences entry or when the edition was deferred
   (2020), so it is safe to include unconditionally.

   The conference name and description stay in English on all locales
   (the event's canonical name, matching the site convention), while
   `inLanguage` reflects the page. `url` points at the canonical English
   page on every locale so the three pages describe one event, not three. #}
{%- set _c = conferences.byYear[year or archiveSlug] -%}
{%- if _c and not _c.deferred -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "European Security Studies Conference {{ _c.year }}",
  "description": "{{ _c.archiveMeta.en }}",
  "startDate": "{{ _c.startDate }}",
  "endDate": "{{ _c.endDate }}",
  "inLanguage": "{{ lang or 'en' }}",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/{{ 'MixedEventAttendanceMode' if _c.livestreamUrl else 'OfflineEventAttendanceMode' }}",
  "location": [
    {
      "@type": "Place",
      "name": "{{ _c.venue.en }}",
      "address": "{{ _c.mapEmbed.address.en if (_c.mapEmbed and _c.mapEmbed.address) else (_c.city ~ ', ' ~ _c.country) }}"
    }{%- if _c.livestreamUrl %},
    {
      "@type": "VirtualLocation",
      "url": "{{ _c.livestreamUrl }}"
    }{%- endif %}
  ],
  "organizer": {
    "@type": "Organization",
    "name": "{{ site.fullName }}",
    "url": "{{ site.url }}/"
  },
  "image": "{{ site.url }}/assets/images/past-meta.jpg",
  "url": "{{ site.url }}/{{ _c.slug }}.html"
}
</script>
{%- endif -%}
