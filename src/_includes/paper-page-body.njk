{# Visible body of a per-paper landing page (#794). `paper` is the pagination
   alias from paper.njk. Reuses existing page-header / prose / btn classes, so
   no new CSS. Authors that are EISS members link to their profile. #}
{% from "icons.njk" import icon %}

<header class="page-header">
  <div class="container">
    <span class="eyebrow"><a href="{{ paper.conferenceUrl }}">{{ paper.conferenceLabel }} {{ paper.year }}</a></span>
    <h1 lang="en">{{ paper.title }}</h1>
    {%- if paper.authorsLinked and paper.authorsLinked.length %}
    <p class="page-lead" lang="en">
      {%- for a in paper.authorsLinked -%}
        {%- if a.url %}<a href="{{ a.url }}">{{ a.name }}</a>{% else %}{{ a.name }}{% endif %}{% if not loop.last %}, {% endif %}
      {%- endfor -%}
    </p>
    {%- endif %}
    {%- if paper.affiliations and paper.affiliations.length %}
    <p class="muted" lang="en">{{ paper.affiliations | join(' · ') }}</p>
    {%- endif %}
  </div>
</header>

<section class="section-tight">
  <div class="container">
    <article class="prose" lang="en" style="max-width: 48rem;">
      {%- if paper.abstract %}
      <h2>Abstract</h2>
      <p>{{ paper.abstract }}</p>
      {%- endif %}
      {%- if paper.panel %}
      <p class="muted" lang="en"><strong>Panel:</strong> {{ paper.panel }}</p>
      {%- endif %}
      {%- if paper.doi %}
      <p class="muted">DOI: <a href="https://doi.org/{{ paper.doi }}">{{ paper.doi }}</a></p>
      {%- endif %}
      <p style="margin-top: var(--space-5); display: flex; gap: var(--space-3); flex-wrap: wrap;">
        {%- if paper.publishedUrl %}<a class="btn btn-primary btn-sm" href="{{ paper.publishedUrl }}" target="_blank" rel="noopener">{{ icon("external-link") }} Read the published version</a>{% endif %}
        {%- if paper.abstractUrl %}<a class="btn btn-secondary btn-sm" href="{{ paper.abstractUrl }}" target="_blank" rel="noopener">{{ icon("external-link") }} View on Indico</a>{% endif %}
        <a class="btn btn-ghost btn-sm" href="{{ paper.conferenceUrl }}#programme">{{ icon("file-text") }} {{ paper.conferenceLabel }} {{ paper.year }} programme</a>
        <a class="btn btn-ghost btn-sm" href="/papers.html#paper-{{ paper.slug }}">All papers</a>
      </p>
    </article>
  </div>
</section>

{# ScholarlyArticle structured data (string values dumped so quotes in
   titles/abstracts can't break the JSON). #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  "headline": {{ paper.title | dump | safe }},
  "name": {{ paper.title | dump | safe }},
  "author": [{% for a in paper.authorNames %}{ "@type": "Person", "name": {{ a | dump | safe }} }{% if not loop.last %}, {% endif %}{% endfor %}],
  "datePublished": "{{ paper.year }}",
  "isPartOf": { "@type": "Event", "name": "European Security Studies Conference {{ paper.year }}" },
  "publisher": { "@type": "Organization", "name": "European Initiative for Security Studies" },
  {% if paper.abstract %}"abstract": {{ paper.abstract | dump | safe }},{% endif %}
  "inLanguage": "en",
  "url": {{ (site.url + "/papers/" + paper.slug + ".html") | dump | safe }}
}
</script>
