{# Visible body of a per-paper landing page (#794). `paper` is the pagination
   alias from paper.njk. Reuses existing page-header / prose / btn classes, so
   no new CSS. Authors that are EISS members link to their profile. #}
{% from "icons.njk" import icon %}

{# Mobile-only sticky Back (#889, item 4). Keeps an entry-aware exit in reach
   while scrolling a long abstract. Hidden on desktop, where the breadcrumb sits
   at the top. paper-back.js upgrades every [data-paper-back] (this + the
   in-article one) to history.back() with a referrer-aware label. #}
<div class="paper-back-sticky">
  <div class="container">
    <a class="btn btn-secondary btn-sm" href="/anthology.html?view=papers#paper-{{ paper.slug }}"
       data-paper-back
       data-back-conf-path="{{ paper.conferenceUrl }}"
       data-back-event="{{ paper.conferenceLabel }} {{ paper.year }}"
       data-back-anthology="Back to the Anthology"
       data-back-generic="Back">{{ icon("arrow-left") }} <span data-back-label>All papers</span></a>
  </div>
</div>

<header class="page-header">
  <div class="container">
    {# Breadcrumb trail (#889, item 2): a fixed second exit, correct even on a
       direct landing from search and independent of the referrer. EN-only,
       like the rest of this page. The visible trail and the BreadcrumbList
       JSON-LD at the foot are kept identical. #}
    <nav class="breadcrumb" aria-label="Breadcrumb" lang="en">
      <a href="/">EISS</a>
      <a href="/anthology.html">Anthology</a>
      <a href="{{ paper.conferenceUrl }}">{{ paper.conferenceLabel }} {{ paper.year }}</a>
      <span aria-current="page">{{ paper.title }}</span>
    </nav>
    <h1 lang="en">{{ paper.title }}</h1>
    {%- if paper.prize %}
    {# Early-Career Researcher Best Paper Prize winner (EISS × Journal of
       Strategic Studies). EN only, like the rest of this page. #}
    <p class="paper-prize-line" lang="en">{{ icon("award") }} <strong>{{ paper.prize.award }}</strong> &middot; EISS &times; {{ paper.prize.partner }} &middot; {{ paper.year }}</p>
    {%- endif %}
    {%- if paper.authorsLinked and paper.authorsLinked.length %}
    <p class="page-lead" lang="en">
      {%- for a in paper.authorsLinked -%}
        {%- if a.url %}<a href="{{ a.url }}">{{ a.name }}</a>{% else %}{{ a.name }}{% endif %}{% if not loop.last %}, {% endif %}
      {%- endfor -%}
    </p>
    {%- endif %}
    {%- if paper.affiliations and paper.affiliations.length %}
    <p class="muted" lang="en">{{ paper.affiliations | join(' · ') }}</p>
    {%- endif %}
  </div>
</header>

<section class="section-tight">
  <div class="container">
    <article class="prose" lang="en" style="max-width: 48rem;">
      {%- if paper.publishedUrl %}
      {# Published version (#805). Auto-matched by author + title, so flagged a
         "Beta feature" that may be wrong. The outlet line, author byline and
         BibTeX come from Crossref via scripts/enrich-publications.mjs; any
         field may be absent. The published byline can differ from the
         conference presenters. #}
      {%- set _isPreprint = paper.publishedType and ("preprint" in paper.publishedType | lower or "working" in paper.publishedType | lower) -%}
      <aside class="pub-match" aria-labelledby="pub-match-h-{{ paper.slug }}">
        <div class="pub-match-head">
          <span class="pub-match-badge">Beta feature</span>
          <h2 class="pub-match-title" id="pub-match-h-{{ paper.slug }}">Published version</h2>
          {%- if paper.publishedType %}<span class="pub-type-chip">{{ paper.publishedType }}</span>{% endif %}
        </div>
        <p class="pub-match-lead">
          Presented at <a href="{{ paper.conferenceUrl }}">{{ paper.conferenceLabel }} {{ paper.year }}</a>, {% if _isPreprint %}later released as a preprint{% elif paper.publishedJournal %}later published in <em lang="en">{{ paper.publishedJournal }}</em>{% else %}later published{% endif %}{% if paper.publishedYear %} ({{ paper.publishedYear }}){% endif %}.
        </p>
        {%- if paper.publishedTitle %}
        {# The published title can differ from the conference title, so it is
           always shown verbatim. #}
        <p class="pub-match-pubtitle" lang="en">“{{ paper.publishedTitle }}”</p>
        {%- endif %}
        <dl class="pub-match-meta">
          {%- if paper.publishedAuthors.length %}
          {# The published byline can add or drop co-authors versus the
             conference presenters, so it is listed in full. #}
          <dt>Published as</dt><dd lang="en">{{ paper.publishedAuthors | join(', ') }}</dd>
          {%- endif %}
          {%- if paper.publishedJournal %}
          <dt>Outlet</dt><dd lang="en">{{ paper.publishedJournal }}{% if paper.publishedVolume %}, vol.&nbsp;{{ paper.publishedVolume }}{% endif %}{% if paper.publishedIssue %}, no.&nbsp;{{ paper.publishedIssue }}{% endif %}{% if paper.publishedPages %}, pp.&nbsp;{{ paper.publishedPages }}{% endif %}</dd>
          {%- elif paper.publishedPublisher %}
          <dt>Outlet</dt><dd lang="en">{{ paper.publishedPublisher }}</dd>
          {%- endif %}
          {%- if paper.doi %}
          <dt>DOI</dt><dd><a href="https://doi.org/{{ paper.doi }}">{{ paper.doi }}</a></dd>
          {%- endif %}
        </dl>
        <div class="pub-match-actions">
          <a class="btn btn-secondary btn-sm" href="{{ paper.publishedUrl }}" target="_blank" rel="noopener">{{ icon("external-link") }} Read the published version</a>
          {%- if paper.bibtex %}
          <button class="btn btn-secondary btn-sm" type="button" data-bibtex-toggle aria-expanded="false" aria-controls="bibtex-{{ paper.slug }}">{{ icon("file-text") }} Cite (BibTeX)</button>
          {%- endif %}
        </div>
        {%- if paper.bibtex %}
        <div class="pub-bibtex" id="bibtex-{{ paper.slug }}" hidden>
          <button class="pub-bibtex-copy" type="button" data-bibtex-copy>Copy</button>
          <pre><code>{{ paper.bibtex }}</code></pre>
        </div>
        {%- endif %}
        <p class="pub-match-note">Matched automatically by comparing authors and titles, so it may be inaccurate, and the published author list can differ from the conference presenters. <a href="mailto:{{ site.contactEmail }}?subject=Publication%20match%3A%20{{ paper.slug }}">Let us know</a> if it looks wrong.</p>
      </aside>
      {%- endif %}
      {%- if paper.abstract %}
      <h2>Abstract</h2>
      <p>{{ paper.abstract }}</p>
      {%- endif %}
      {%- if paper.panel %}
      {# Panel title links to that panel's anchor in the edition programme. #}
      <p class="muted" lang="en"><strong>Panel:</strong> <a href="{{ paper.conferenceUrl }}#panel-{{ paper.panel | slugify }}">{{ paper.panel }}</a></p>
      {%- endif %}
      {# Adaptive Back (#889). Stands apart from the secondary actions and is a
         touch larger, with a return arrow. Baseline: a real anchor to the index
         at this paper's anchor. paper-back.js upgrades it to history.back() with
         a referrer-aware label when the reader came from a same-origin page,
         returning them to their exact filtered index + scroll. #}
      <p style="margin-top: var(--space-5);">
        <a class="btn btn-secondary" href="/anthology.html?view=papers#paper-{{ paper.slug }}"
           data-paper-back
           data-back-conf-path="{{ paper.conferenceUrl }}"
           data-back-event="{{ paper.conferenceLabel }} {{ paper.year }}"
           data-back-anthology="Back to the Anthology"
           data-back-generic="Back">{{ icon("arrow-left") }} <span data-back-label>All papers</span></a>
      </p>
      <p style="margin-top: var(--space-4); display: flex; gap: var(--space-3); flex-wrap: wrap;">
        {%- if paper.abstractUrl %}<a class="btn btn-secondary btn-sm" href="{{ paper.abstractUrl }}" target="_blank" rel="noopener">{{ icon("external-link") }} View on Indico</a>{% endif %}
        <a class="btn btn-secondary btn-sm" href="{{ paper.conferenceUrl }}#programme">{{ icon("file-text") }} {{ paper.conferenceLabel }} {{ paper.year }} programme</a>
      </p>
      {# Within-edition prev/next (#889, item 3): page through this edition's
         papers in the Anthology's by-paper order, without returning to the index. #}
      {%- if paper.editionPrev or paper.editionNext %}
      <nav class="paper-prevnext" aria-label="More from {{ paper.conferenceLabel }} {{ paper.year }}">
        {%- if paper.editionPrev %}
        <a class="paper-prevnext__link paper-prevnext__prev" href="/papers/{{ paper.editionPrev.slug }}.html" rel="prev">
          {{ icon("arrow-left") }}
          <span class="paper-prevnext__body"><span class="paper-prevnext__label">Previous in {{ paper.conferenceLabel }} {{ paper.year }}</span><span class="paper-prevnext__title" lang="en">{{ paper.editionPrev.title }}</span></span>
        </a>
        {%- endif %}
        {%- if paper.editionNext %}
        <a class="paper-prevnext__link paper-prevnext__next" href="/papers/{{ paper.editionNext.slug }}.html" rel="next">
          <span class="paper-prevnext__body"><span class="paper-prevnext__label">Next in {{ paper.conferenceLabel }} {{ paper.year }}</span><span class="paper-prevnext__title" lang="en">{{ paper.editionNext.title }}</span></span>
          {{ icon("arrow-right") }}
        </a>
        {%- endif %}
      </nav>
      {%- endif %}
    </article>
  </div>
</section>

{# ScholarlyArticle structured data (string values dumped so quotes in
   titles/abstracts can't break the JSON). #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  "headline": {{ paper.title | dump | safe }},
  "name": {{ paper.title | dump | safe }},
  "author": [{% for a in paper.authorNames %}{ "@type": "Person", "name": {{ a | dump | safe }} }{% if not loop.last %}, {% endif %}{% endfor %}],
  "datePublished": "{{ paper.year }}",
  "isPartOf": { "@type": "Event", "name": "European Security Studies Conference {{ paper.year }}" },
  "publisher": { "@type": "Organization", "name": "European Initiative for Security Studies" },
  {% if paper.abstract %}"abstract": {{ paper.abstract | dump | safe }},{% endif %}
  "inLanguage": "en",
  "url": {{ (site.url + "/papers/" + paper.slug + ".html") | dump | safe }}
}
</script>

{# BreadcrumbList (#889, item 2) — identical to the visible trail above. #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "EISS", "item": {{ (site.url + "/") | dump | safe }} },
    { "@type": "ListItem", "position": 2, "name": "Anthology", "item": {{ (site.url + "/anthology.html") | dump | safe }} },
    { "@type": "ListItem", "position": 3, "name": {{ (paper.conferenceLabel + " " + (paper.year | string)) | dump | safe }}, "item": {{ (site.url + paper.conferenceUrl) | dump | safe }} },
    { "@type": "ListItem", "position": 4, "name": {{ paper.title | dump | safe }}, "item": {{ (site.url + "/papers/" + paper.slug + ".html") | dump | safe }} }
  ]
}
</script>
{%- if paper.bibtex %}<script src="{{ '/assets/js/paper-cite.js' | bust }}" defer></script>{% endif %}
<script src="{{ '/assets/js/paper-back.js' | bust }}" defer></script>
