{# Prizes page body (#639), shared by the three locale pages. The laureate
   roll is read from prizeLaureates.js, which derives it from the Anthology
   corpus — so each laureate links straight to its /papers/<slug> entry (the
   abstract, the published version, the citation already live there) and
   adding a year stays a one-line edit to paperPrizes.json. Chrome strings
   come from i18n; laureate titles + names are English, like the Anthology. #}
{% from "icons.njk" import icon %}
<header class="page-header">
  <div class="container">
    {# Co-branding: EISS and the Journal of Strategic Studies, who jointly
       award the prize. The EISS lockup is the real brand SVG; the JSS mark
       is a typographic wordmark (no official JSS logo asset on file —
       swap in src/assets/images/brand/ if one is added). #}
    <div class="prize-partners" role="img" aria-label="{{ t.prizes.partner }}">
      <span class="prize-partner prize-partner--eiss" aria-hidden="true">{% inlineSvg "assets/images/brand/logo-lockup.svg" %}</span>
      <span class="prize-partner-sep" aria-hidden="true"></span>
      <a class="prize-partner prize-partner--jss" href="https://www.tandfonline.com/journals/fjss20" target="_blank" rel="noopener" aria-label="Journal of Strategic Studies (opens in a new tab)">
        <span class="jss-mark"><span class="jss-pre">The Journal of</span><span class="jss-name">Strategic Studies</span></span>
      </a>
    </div>
    <span class="eyebrow">{{ t.prizes.eyebrow }}</span>
    <h1>{{ t.prizes.title }}</h1>
    <p class="page-lead">{{ t.prizes.lead }}</p>
  </div>
</header>

<section class="section" aria-labelledby="best-paper-title">
  <div class="container">
    <h2 id="best-paper-title">{{ t.prizes.bestPaperHeading }}</h2>
    <p class="muted" style="max-width: 46rem;">{{ t.prizes.bestPaperIntro }}</p>
    <ol class="laureate-roll">
      {%- for l in prizeLaureates.bestPaper %}
      <li class="laureate">
        <span class="laureate-year">{{ l.year }}</span>
        <span class="laureate-body">
          <a class="laureate-title" href="{{ l.url }}" lang="en">{{ l.title }}</a>
          <span class="laureate-meta" lang="en">{{ l.authors | join(', ') }}{% if l.affiliation %} &middot; {{ l.affiliation }}{% endif %}</span>
        </span>
      </li>
      {%- endfor %}
    </ol>
    <p style="margin-top: var(--space-5);">
      <a class="btn btn-secondary" href="/anthology.html?view=papers&amp;prize=1">{{ t.prizes.seeAll }} {{ icon("arrow-right") }}</a>
    </p>
  </div>
</section>
