{# By-paper panel body of the Conference Navigator (#756). Rendered inside
   archive-page.njk's papers panel, which provides the page header, the
   section/container wrapper and the view toggle. The list is server-rendered
   (not JS-built) so Pagefind indexes every title on the URL that defaults to
   this view. All chrome is `t.papers.*`; the data (paperIndex.papers) is
   identical across locales, so paper titles, author names, affiliations and
   theme labels stay in their original language (lang="en"). `paper-filter.js`
   reads its live-region strings from the data-* attributes on
   [data-paper-status]; filtering matches on data attributes, not visible
   text, so it stays locale-agnostic. #}
{% from "icons.njk" import icon %}
{%- set t = i18n[lang or "en"] -%}
{%- set p18n = t.papers -%}

<div class="speaker-filters" role="search">
  <div class="speaker-field speaker-field--search">
    <label class="speaker-field-label" for="paper-find">{{ p18n.findLabel }}</label>
    <input id="paper-find" type="search" data-paper-find placeholder="{{ p18n.findPlaceholder }}" autocomplete="off">
  </div>
  <div class="speaker-field">
    <label class="speaker-field-label" for="paper-event">{{ p18n.eventLabel }}</label>
    <select id="paper-event" data-paper-event>
      <option value="">{{ p18n.allEvents }} ({{ paperIndex.stats.paperCount }})</option>
      {%- for ed in paperIndex.editions %}
      <option value="{{ ed.key }}">{{ ed.label }}{% if ed.year %} {{ ed.year }}{% endif %} ({{ ed.count }})</option>
      {%- endfor %}
    </select>
  </div>
  <div class="speaker-field">
    <label class="speaker-field-label" for="paper-theme">{{ p18n.themeLabel }}</label>
    <select id="paper-theme" data-paper-theme>
      <option value="">{{ p18n.allThemes }} ({{ paperIndex.stats.paperCount }})</option>
      {%- for th in paperIndex.themes %}
      <option value="{{ th.name }}">{{ th.name }} ({{ th.count }})</option>
      {%- endfor %}
    </select>
  </div>
  <div class="speaker-field speaker-field--check">
    <label class="speaker-field-label--check" for="paper-published">
      <input type="checkbox" id="paper-published" data-paper-published data-label="{{ p18n.publishedOnly }}">
      {{ p18n.publishedOnly }}
    </label>
  </div>
  <div class="speaker-field speaker-field--check">
    <label class="speaker-field-label--check" for="paper-prize">
      <input type="checkbox" id="paper-prize" data-paper-prize data-label="{{ p18n.prizeOnly }}">
      {{ p18n.prizeOnly }}
    </label>
  </div>
  <button type="button" class="btn btn-sm speaker-clear" data-paper-clear hidden>{{ p18n.clear }}</button>
</div>

{# Filter status, announced to assistive tech (role=status → polite live
   region). Empty when nothing is filtered. The data-msg-* strings are
   the localised templates paper-filter.js fills in. #}
<p class="speaker-status" role="status" aria-live="polite" data-paper-status hidden
   data-msg-none="{{ p18n.noMatch }}"
   data-msg-one="{{ p18n.resultsOne }}"
   data-msg-many="{{ p18n.resultsMany }}"
   data-msg-matching="{{ p18n.matching }}"></p>

<ol class="paper-index" role="list" data-paper-list>
  {%- for p in paperIndex.papers %}
  <li class="paper-entry" data-paper-entry
      {% if p.slug %}id="paper-{{ p.slug }}"{% endif %}
      data-event="{{ p.conferenceUrl }}"
      data-themes="{{ p.theme | join('|') }}"
      data-search="{{ p.title }} {{ p.authors | join(' ') }} {{ p.affiliations | join(' ') }}"
      {% if p.publishedUrl %}data-published="1"{% endif %}
      {% if p.prize %}data-prize="1"{% endif %}>
    <article class="paper-card">
      <h2 class="paper-title" lang="en">{% if p.paperUrl %}<a href="{{ p.paperUrl }}">{{ p.title }}</a>{% else %}{{ p.title }}{% endif %}{%- if p.publishedUrl %}<span class="paper-pub-chip" lang="en" title="A published version of this paper exists">Published</span>{% endif %}{%- if p.prize %}<span class="paper-prize-chip" lang="en" title="{{ p.prize.award }} — EISS × {{ p.prize.partner }}">{{ icon("award") }} {{ p.prize.award }}</span>{% endif %}</h2>
      {%- if p.authorsLinked.length %}
      {# Authors that are EISS board / community members link through to their
         profile page (the by-paper → by-person cross-link); others are plain. #}
      <p class="paper-authors" lang="en">
        {%- for a in p.authorsLinked -%}
        {%- if a.url %}<a href="{{ a.url }}">{{ a.name }}</a>{% else %}{{ a.name }}{% endif %}{% if not loop.last %}, {% endif %}
        {%- endfor -%}
      </p>
      {%- endif %}
      {%- if p.affiliations.length %}
      <p class="paper-aff muted" lang="en">{{ p.affiliations | join(' · ') }}</p>
      {%- endif %}
      <p class="paper-meta">
        <a class="paper-edition" href="{{ p.programmeUrl }}">{{ p.conferenceLabel }}{% if p.year %} {{ p.year }}{% endif %}</a>
        {%- if p.panel %}<span class="paper-panel muted" lang="en">{{ p.panel }}</span>{% endif %}
      </p>
      {%- if p.theme.length %}
      <p class="paper-themes">
        {%- for th in p.theme %}<span class="paper-theme-chip" lang="en">{{ th }}</span>{% endfor %}
      </p>
      {%- endif %}
    </article>
  </li>
  {%- endfor %}
</ol>

<p class="muted" style="margin-top: var(--space-6); font-size: var(--fs-sm); max-width: 44rem;">
  {{ p18n.note }}
</p>

<script src="{{ '/assets/js/paper-filter.js' | bust }}" defer></script>
