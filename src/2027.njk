{# ============================================================
   HIDDEN TEMPLATE — ESSC 2027 (not built; listed in .eleventyignore).

   A copy of the live ESSC 2026 page with every "2026" bumped to
   "2027", kept so the next edition starts from a working page
   rather than a blank file. To activate, follow docs/new-conference.md:

     1. Add the 2027 entry to src/_data/conferences.js.
     2. Replace the Stockholm-specific copy below: city, venue,
        dates, hero image, the neighbourhoods/travel tiles, the
        host & venue card, and the map embed.
     3. Generate the 2027 share card (scripts/make-share-cards.py)
        and confirm metaImage points at /assets/images/2027-meta.jpg.
     4. Register the FR/DE translations in data/i18n-state.json and
        run check-i18n-drift.py --mark-fresh.
     5. Remove this file (and its FR/DE siblings) from .eleventyignore
        so it builds.

   Until step 5 this file is inert: Eleventy never renders it, so the
   2027 conference data it references not yet existing is harmless.
   ============================================================ #}
{% from "icons.njk" import icon %}

{# schema.org Event structured data for this edition (built from
   conferences.js). Renders into the body, which is valid for JSON-LD. #}
{% set year = "2027" %}
{% include "event-jsonld.njk" %}

<section class="hero" aria-labelledby="hero-title-2027">
  <div class="hero-bg" aria-hidden="true">
    <img src="/assets/images/8e43301e-7945-4a0c-aac2-04719ac702a8-1600x900.jpg"
         srcset="/assets/images/8e43301e-7945-4a0c-aac2-04719ac702a8-480x270.jpg 480w,
                 /assets/images/8e43301e-7945-4a0c-aac2-04719ac702a8-800x450.jpg 800w,
                 /assets/images/8e43301e-7945-4a0c-aac2-04719ac702a8-1600x900.jpg 1600w"
         sizes="100vw"
         alt=""
         loading="eager"
         fetchpriority="high"
         width="1600" height="900">
  </div>
  <div class="container hero-inner">
    <p class="reveal" style="font-size: var(--fs-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: hsl(0 0% 100% / 0.85); margin-bottom: var(--space-3);">
      Next Annual Conference
    </p>
    <h1 id="hero-title-2027" class="reveal reveal-delay-1" style="font-size: clamp(2.25rem, 1.6rem + 3vw, 4rem);">
      European Security Studies Conference 2027
    </h1>
    <p class="hero-tagline reveal reveal-delay-2">
      Jointly organised by the COST Action NetSec, the European Initiative for Security Studies (EISS),
      and Stockholm University.
    </p>
    {%- set _live2027 = conferences.byYear["2027"] -%}
    {%- set _liveShown = _live2027 and _live2027.livestreamUrl and _live2027.endDate >= conferences.today -%}
    <div class="hero-actions reveal reveal-delay-3">
      {%- if _liveShown %}
      <a class="btn btn-primary hero-watch-live" href="{{ _live2027.livestreamUrl }}" target="_blank" rel="noopener">
        <span class="hero-watch-live__dot" aria-hidden="true"></span>{{ icon("video") }} Livestream {{ icon("external-link") }}
      </a>
      {%- endif %}
      <a class="btn {{ 'btn-ghost' if _liveShown else 'btn-primary' }}" href="#programme">{{ icon("file-text") }} View programme</a>
      <a class="btn btn-ghost" href="#venue">{{ icon("map-pin") }} Host &amp; venue</a>
    </div>
    <p class="reveal reveal-delay-3" style="margin-top: var(--space-6); font-size: var(--fs-sm); color: hsl(0 0% 100% / 0.9);">
      <strong>11 - 12 June 2027</strong>
      <span aria-hidden="true">&nbsp;·&nbsp;</span>
      Stockholm University, Sweden
    </p>
    {# Live registration-status badge. Computed from today vs. the
       conference dates in src/_data/conferences.js; CTA URL comes
       from the Indico sync in src/_data/indico.json. #}
    {% set year = "2027" %}
    <div class="reveal reveal-delay-3 conf-status-row">
      {% include "registration-badge.njk" %}
      {% include "countdown.njk" %}
    </div>
    {%- set _reg2027 = conferences.byYear["2027"] -%}
    {%- if _reg2027 and _reg2027.registrationStatus == "closed" -%}
    <p class="reveal reveal-delay-3" style="margin-top: var(--space-4); font-size: var(--fs-sm); color: hsl(0 0% 100% / 0.9); max-width: 42rem;">
      Registration has closed. You can still follow along: the <a href="#programme" style="color:#fff;text-decoration:underline;">programme</a> below marks the livestreamed sessions.
    </p>
    {%- endif -%}
  </div>
</section>

{# Joint-organisers strip. Restates the collaboration footprint as a
   structured component below the hero, so the relationship reads
   visually rather than as a sentence buried in the tagline. Logo
   paths are placeholders for now (partial gracefully falls back to
   text-only when `logo` is absent); operator fills in real logo
   files when they're available. See issue #198. #}
<section class="section" aria-label="Conference organisers" style="padding-block: var(--space-5);">
  <div class="container">
    {%- set jointOrgs = [
      {
        "name": "European Initiative for Security Studies (EISS)",
        "url": "https://eiss-europa.com/",
        "logo": "/assets/images/partners/eiss-lockup.svg"
      },
      {
        "name": "NetSec (COST Action CA24154)",
        "url": "https://netsec-cost.eu/",
        "logo": "/assets/images/partners/netsec.svg"
      },
      {
        "name": "Stockholm University",
        "url": "https://www.su.se/",
        "logo": "/assets/images/partners/stockholm-university.svg"
      }
    ] -%}
    {% include "joint-orgs.njk" %}
  </div>
</section>

