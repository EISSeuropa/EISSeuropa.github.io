<header class="page-header">
  <div class="container">
    <span class="eyebrow">Über uns</span>
    <h1>Die Personen</h1>
    <p class="page-lead">
      Unsere Vorstandsmitglieder beraten und steuern die Organisation, insbesondere durch thematische
      Arbeitsgruppen (WG). Ein kleines Unterstützungsteam wickelt das Tagesgeschäft ab.
    </p>
    <p class="page-lead muted" style="font-size: var(--fs-sm); margin-top: var(--space-3);">
      <em>Namen, Zugehörigkeiten und Forschungsthemen unten bleiben in der Originalsprache.</em>
    </p>
  </div>
</header>

<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Vorstand</h2>
    <div class="people-grid">
      {%- for person in board.members %}
      <article class="person">
        <img class="person-photo" src="{{ person.photo }}" alt="{{ person.alt or person.name }}" loading="lazy">
        <div class="person-body">
          <p class="person-role">{{ person.role }}</p>
          <p class="person-name">{{ person.name }}</p>
          <p class="person-affiliation">{{ person.affiliation | safe }}</p>
          {%- if person.themes %}
          <p class="person-affiliation muted" style="margin-top: var(--space-2); font-size: var(--fs-xs); border-top: 1px solid var(--border); padding-top: var(--space-2);"><strong>Forschungsthemen:</strong> {{ person.themes | safe }}</p>
          {%- endif %}
        </div>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <h2 style="margin-bottom: var(--space-5);">Unterstützungsteam</h2>
    <div class="people-grid">
      {%- for person in board.support %}
      <article class="person">
        <img class="person-photo" src="{{ person.photo }}" alt="{{ person.alt or person.name }}" loading="lazy">
        <div class="person-body">
          <p class="person-role">{{ person.role }}</p>
          <p class="person-name">{{ person.name }}</p>
          <p class="person-affiliation">{{ person.bio | safe }}</p>
        </div>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>
